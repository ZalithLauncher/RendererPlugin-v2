<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@drawable/img_app"
        android:label="@string/app_name"
        android:supportsRtl="true">

        <activity
            android:name=".client.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <provider
            android:name=".RendererProvider"
            android:authorities="${applicationId}.renderer"
            android:exported="true"
            android:grantUriPermissions="false"
            tools:ignore="ExportedContentProvider" >

            <meta-data
                android:name="fclPlugin_V2"
                android:value="true" />

            <meta-data
                android:name="fclPlugin_Type"
                android:value="renderer" />

        </provider>

    </application>

</manifest>