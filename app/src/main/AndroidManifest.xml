<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@drawable/img_app"
        android:label="@string/app_name"
        android:supportsRtl="true">

        <activity
            android:name=".client.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--  由启动器后台静默启动，读取配置后广播返回  -->
        <activity
            android:name=".client.ConfigProviderActivity"
            android:theme="@style/Theme.Transparent"
            android:exported="true"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:taskAffinity=""
            android:finishOnTaskLaunch="true">
            <intent-filter>
                <action android:name="com.launchers_plugin.renderer.REQUEST_CONFIG" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <meta-data
            android:name="fclPlugin"
            android:value="true" />

        <meta-data
            android:name="fclPlugin_V2"
            android:value="true" />

        <!--    兼容旧版渲染器插件架构    -->
        <meta-data
            android:name="des"
            android:value="${des}" />
        <meta-data
            android:name="renderer"
            android:value="${renderer}" />
        <meta-data
            android:name="boatEnv"
            android:value="${boatEnv}" />
        <meta-data
            android:name="pojavEnv"
            android:value="${pojavEnv}" />
        <meta-data
            android:name="minMCVer"
            android:value="${minMCVer}" />
        <meta-data
            android:name="maxMCVer"
            android:value="${maxMCVer}" />

    </application>

</manifest>